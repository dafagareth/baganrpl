# Salin file ini ke .env dan isi nilainya
# cp .env.example .env

# Django secret key (generate baru untuk production)
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=ganti-dengan-secret-key-yang-kuat

# Mode debug (True untuk development, False untuk production)
DEBUG=True

# Host yang diizinkan (pisahkan dengan koma, tanpa spasi)
# Produksi (Cloudflare Tunnel): isi domain kamu, mis. bagan.my.id,www.bagan.my.id
ALLOWED_HOSTS=127.0.0.1,localhost

# Origin tepercaya untuk CSRF (wajib di produksi HTTPS). Pisahkan koma.
# Produksi: https://bagan.my.id,https://www.bagan.my.id
CSRF_TRUSTED_ORIGINS=https://bagan.my.id

# Cloudflare yang menangani HTTPS (kirim X-Forwarded-Proto: https). Biarkan
# False agar tidak terjadi redirect loop; aktifkan "Always Use HTTPS" di Cloudflare.
SECURE_SSL_REDIRECT=False

# Firebase Cloud Messaging (opsional)
# Kosongkan jika belum setup Firebase — FCM dilewati, Notification DB tetap jalan
FIREBASE_CREDENTIALS_PATH=

# Password PostgreSQL untuk Docker (dipakai docker-compose; default: bagan123).
# Hanya relevan saat `docker compose up`. Dev lokal tetap pakai SQLite otomatis.
DB_PASSWORD=bagan123
